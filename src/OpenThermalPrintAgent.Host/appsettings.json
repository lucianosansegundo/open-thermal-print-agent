{
  "Agent": {
    "Port": 17890,
    "AllowedOrigins": [
      "http://localhost:5173",
      "https://localhost:5173"
    ],
    "MaxRequestBodyBytes": 65536,
    "Security": {
      "RequireToken": false,
      "Token": "",
      "HeaderName": "X-OpenThermalPrintAgent-Token"
    },
    "Queue": {
      "Enabled": false,
      "RetryAttempts": 2,
      "RetryDelayMilliseconds": 500,
      "MaxRecentJobs": 100
    }
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "127.0.0.1;localhost"
}
